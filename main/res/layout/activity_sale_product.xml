<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#BFE7DE"
    android:id="@+id/scrollView"
    tools:context=".SaleProductActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/sale_product_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Custom Toolbar with centered title -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar_sale_product"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:background="#013137"
            app:navigationIcon="@android:drawable/ic_menu_revert"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/toolbar_title"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="Sale Product"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
        </androidx.appcompat.widget.Toolbar>

        <!-- Button Container for Mode Selection -->
        <LinearLayout
            android:id="@+id/buttonContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="24dp"
            android:background="#BFE7DE"
            android:padding="4dp"
            app:layout_constraintTop_toBottomOf="@id/toolbar_sale_product"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Single Sale Button -->
            <TextView
                android:id="@+id/btnSingleSale"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Single Sale"
                android:textColor="#013137"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/rounded_button_background"
                android:padding="12dp"
                android:gravity="center"
                android:layout_marginEnd="2dp" />

            <!-- Multiple Sales Button -->
            <TextView
                android:id="@+id/btnMultipleSales"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Multiple Sales"
                android:textColor="#013137"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/rounded_button_background"
                android:padding="12dp"
                android:gravity="center"
                android:layout_marginStart="2dp" />

        </LinearLayout>

        <!-- Single Sale Section -->
        <LinearLayout
            android:id="@+id/singleSaleSection"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="24dp"
            app:layout_constraintTop_toBottomOf="@id/buttonContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Label: Product Name -->
            <TextView
                android:id="@+id/labelProductName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Product Name"
                android:textColor="#013137"
                android:textSize="14sp"
                android:layout_marginTop="16dp" />

            <!-- Product Name -->
            <EditText
                android:id="@+id/etProductName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:background="@android:drawable/editbox_background_normal"
                android:hint="Enter product name"
                android:inputType="textCapWords"
                android:padding="12dp"
                android:textColor="#000000" />

            <!-- Label: Price -->
            <TextView
                android:id="@+id/labelPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Price"
                android:textColor="#013137"
                android:textSize="14sp"
                android:layout_marginTop="16dp" />

            <!-- Price -->
            <EditText
                android:id="@+id/etPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter price (e.g., 100, $100, €100, Rs100)"
                android:padding="12dp"
                android:inputType="text"
                android:background="@android:drawable/editbox_background_normal"
                android:textColor="#000000"
                android:layout_marginTop="2dp" />

            <!-- Label: Quantity -->
            <TextView
                android:id="@+id/labelQuantity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quantity"
                android:textColor="#013137"
                android:textSize="14sp"
                android:layout_marginTop="16dp" />

            <!-- Quantity -->
            <EditText
                android:id="@+id/etQuantity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter quantity"
                android:padding="12dp"
                android:inputType="text"
                android:background="@android:drawable/editbox_background_normal"
                android:textColor="#000000"
                android:layout_marginTop="2dp" />

            <!-- Label: Sale Date -->
            <TextView
                android:id="@+id/labelSaleDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sale Date"
                android:textColor="#013137"
                android:textSize="14sp"
                android:layout_marginTop="16dp" />

            <!-- Sale Date -->
            <EditText
                android:id="@+id/etDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Select sale date"
                android:padding="12dp"
                android:focusable="false"
                android:inputType="date"
                android:background="@android:drawable/editbox_background_normal"
                android:textColor="#000000"
                android:layout_marginTop="2dp" />

            <!-- Bill Amount -->
            <TextView
                android:id="@+id/tvBillAmount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Total Bill: 0.00"
                android:textColor="#013137"
                android:textSize="18sp"
                android:textStyle="bold"
                android:background="@drawable/rounded_button_background"
                android:padding="12dp"
                android:layout_marginTop="24dp"
                android:gravity="center" />

            <!-- Sale Button -->
            <Button
                android:id="@+id/btnSaleProduct"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sale Product"
                android:background="@drawable/rounded_button_background"
                android:textColor="#FFFFFF"
                android:layout_marginTop="24dp" />

        </LinearLayout>

        <!-- Multiple Sales Section -->
        <LinearLayout
            android:id="@+id/multipleSalesSection"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="24dp"
            app:layout_constraintTop_toBottomOf="@id/buttonContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Multiple Sales Container -->
            <LinearLayout
                android:id="@+id/multipleSalesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
